:80 {
    # 1) API sempre vai para o backend
    handle /api/* {
        reverse_proxy localhost:8000
    }

    # 1b) Health check e arquivos servidos pelo backend
    handle /health {
        reverse_proxy localhost:8000
    }
    handle /outputs/* {
        reverse_proxy localhost:8000
    }

    # 2) Frontend SPA
    root * /app/dist
    handle {
        try_files {path} /index.html
        file_server
    }

    # Logging
    log {
        output stdout
    }
}
